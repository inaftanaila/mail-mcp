# Apple Mail MCP Server Configuration
# Copy this file to .env and adjust values as needed

# Transport type: stdio or http
# Default: stdio
TRANSPORT=stdio

# HTTP server port (only used when TRANSPORT=http)
# Default: 8787
PORT=8787

# HTTP server host (only used when TRANSPORT=http)
# Default: localhost
HOST=localhost

# Account access policy (optional)
# Use one of these, not both:
# - ALLOWED: only listed account names/email identities can be used
# - BLOCKED: listed account names/email identities are denied
# Values are comma-separated. Matching is case-insensitive.
#
# APPLE_MAIL_MCP_ALLOWED_ACCOUNTS="Work,work@example.com"
# APPLE_MAIL_MCP_BLOCKED_ACCOUNTS="Private,private@example.com"
